rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;

      // Only create your own document, with validated fields only
      allow create: if request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['displayName','photoURL','friendCode','friends','createdAt','xpTotal','xpSpent','xpAvailable'])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 100
        && request.resource.data.friends is list
        && request.resource.data.friends.size() == 0
        && request.resource.data.xpTotal == 0
        && request.resource.data.xpSpent == 0
        && request.resource.data.xpAvailable == 0;

      // Owner can update display fields only, or XP fields only (with invariant enforced).
      // XP fields are NOT freely writable — splitting prevents mixing display + XP in one write,
      // and the invariant (xpAvailable == xpTotal - xpSpent) must always hold.
      // Note: full prevention of arbitrary XP self-award requires Cloud Functions.
      // Others can only add/remove themselves from friends[] (no duplicates).
      allow update: if (
          request.auth.uid == uid
          && (
            // Case 1: only updating display fields — XP fields must not change
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL'])
            ||
            // Case 2: only updating XP fields — invariant must hold.
            // xpAvailable CAN be negative (user spent XP then reversed a workout).
            (request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['xpTotal', 'xpSpent', 'xpAvailable'])
             && request.resource.data.xpTotal >= 0
             && request.resource.data.xpSpent >= 0
             && request.resource.data.xpAvailable
                  == request.resource.data.xpTotal - request.resource.data.xpSpent)
          )
        )
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends'])
          && (
            // Adding own UID — must not already be in the list (prevents duplicates)
            (request.resource.data.friends.size() == resource.data.friends.size() + 1
             && request.resource.data.friends.hasAll(resource.data.friends)
             && request.resource.data.friends.hasAll([request.auth.uid])
             && !resource.data.friends.hasAll([request.auth.uid]))
            // Removing own UID — must currently be in the list
            || (request.resource.data.friends.size() == resource.data.friends.size() - 1
                && resource.data.friends.hasAll(request.resource.data.friends)
                && resource.data.friends.hasAll([request.auth.uid]))
          )
        );

      allow delete: if false;

      match /xpEvents/{eventKey} {
        allow read: if request.auth.uid == uid;
        // Only the owner can append — update is forbidden
        allow create: if request.auth.uid == uid;
        allow update: if false;
        // Owner may delete reversal events only (allows re-marking a workout after removal)
        // Award events cannot be deleted, preventing double-awarding
        allow delete: if request.auth.uid == uid && resource.data.type == "reversal";
      }
    }

    match /friendCodes/{code} {
      allow read: if request.auth != null;

      // Creator must own the code — prevents namespace squatting
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;

      // Codes are immutable once created
      allow update: if false;
      allow delete: if false;
    }

    match /monthlyRankings/{yearMonth} {
      // Circle snapshots — one per user per month, immutable once created
      match /circles/{uid} {
        // Any authenticated user can read (friends need to see each other's circles)
        allow read: if request.auth != null;
        // Only the owner creates their own circle snapshot
        allow create: if request.auth.uid == uid;
        allow update, delete: if false;
      }

      // Eligibility pairs — sender outranked recipient in this month
      match /pairs/{pairId} {
        // Any authenticated user can read (needed for eligibility checks at purchase time)
        allow read: if request.auth != null;
        // Only the sender can create a pair where they are listed as sender
        allow create: if request.auth != null
          && request.resource.data.senderUid == request.auth.uid;
        // Pairs are immutable (merge:true in client still goes through create rule on first write)
        allow update, delete: if false;
      }
    }

    match /humiliations/{humiliationId} {
      // Only sender and recipient can read their humiliation.
      // resource == null when the document doesn't exist (transaction existence check).
      allow read: if request.auth != null
        && (resource == null
            || request.auth.uid == resource.data.senderUid
            || request.auth.uid == resource.data.recipientUid);

      // Only the sender can create — document ID must be {senderUid}_{recipientUid}_{yearMonth}
      // Eligibility is enforced server-side: the pair doc must exist, confirming sender outranked
      // recipient that month. This prevents crafted writes that bypass client-side checks.
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.senderUid
        && request.resource.data.keys().hasOnly([
             'senderUid','recipientUid','yearMonth','itemId','itemSnapshot',
             'createdAt','senderDisplayName','recipientDisplayName'
           ])
        && request.resource.data.senderUid is string
        && request.resource.data.recipientUid is string
        && request.resource.data.senderUid != request.resource.data.recipientUid
        && exists(/databases/$(database)/documents/monthlyRankings/$(request.resource.data.yearMonth)/pairs/$(request.auth.uid + '_' + request.resource.data.recipientUid));

      // Humiliations are immutable and permanent
      allow update, delete: if false;
    }

    match /workouts/{uid} {
      // Own doc always readable; friends can read if listed in owner's friends[]
      allow read: if request.auth != null
        && (request.auth.uid == uid
            || (
              exists(/databases/$(database)/documents/users/$(uid))
              && request.auth.uid in get(/databases/$(database)/documents/users/$(uid)).data.friends
            ));

      // Only create/update own workouts — delete is not permitted
      // Field validation: only 'dates' (a list) is allowed
      allow create, update: if request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['dates'])
        && request.resource.data.dates is list;
      allow delete: if false;
    }

  }
}
